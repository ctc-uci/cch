{
  "name": "npo-template-merged",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "repository": "git@github.com:ctc-uci/npo-template-merged.git",
  "author": "CTC <ctc@uci.edu>",
  "license": "MIT",
  "scripts": {
    "dev": "yarn tsx concurrently.ts",
    "start": "yarn tsx concurrently.ts",
    "prepare": "husky install",
    "lint": "eslint",
    "format": "npx prettier --write .",
    "postinstall": "cd client && patch-package"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": "yarn run eslint"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@types/lint-staged": "^13.3.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "husky": "^9.0.11",
    "prettier": "3.3.3",
    "typescript-eslint": "^8.1.0"
  },
  "workspaces": {
    "packages": [
      "client",
      "server"
    ],
    "nohoist": [
      "**/firebase",
      "**/firebase/**"
    ]
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "resolutions": {
    "@babel/helpers": "^7.26.10",
    "@babel/runtime": "^7.26.10",
    "@grpc/grpc-js": "^1.11.4",
    "@protobufjs/utf8": "^1.1.1",
    "@remix-run/router": "^1.23.2",
    "@tootallnate/once": "^2.0.1",
    "ajv": "^6.14.0",
    "brace-expansion": "^1.1.13",
    "cookie": "^0.7.0",
    "cross-spawn": "^7.0.5",
    "fast-xml-parser": "^4.5.4",
    "flatted": "^3.4.0",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.4",
    "js-yaml": "^4.1.1",
    "jws": "^4.0.1",
    "micromatch": "^4.0.8",
    "minimatch": "^3.1.3",
    "node-forge": "^1.3.2",
    "path-to-regexp": "^0.1.13",
    "picomatch": "^2.3.2",
    "protobufjs": "^7.5.5",
    "qs": "^6.14.2",
    "semver": "^7.5.2",
    "shell-quote": "^1.8.4",
    "undici": "^6.23.0"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@react-pdf/renderer": "^4.3.0",
    "@tanstack/react-table": "^8.21.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "flag": "^5.0.1"
  }
